{
  "name": "fm-analyzer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": "server.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:exe": "npm run build && pkg . --targets node18-win-x64 --output FMAnalyzer.exe",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "pkg": "^5.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": "dist/**/*",
    "targets": [
      "node18-win-x64"
    ]
  }
}
